generator client {
  provider = "prisma-client-js"
}

datasource db {
  // LOCAL DEV: Use SQLite (change to "postgresql" for Vercel/Supabase)
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Book {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String   // Maps to TEXT in both SQLite and PostgreSQL
  snippet       String   // Free preview text
  fullContent   String   // Full book content (members only)
  coverImage    String   // URL to cover image
  genre         String
  publishedDate String
  featured      Boolean  @default(false)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String    // Short preview
  content     String    // Full blog content (markdown)
  coverImage  String    // URL to cover image
  author      String    @default("Simon J Cleary")
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Member {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String
  stripeCustomerId String?  @unique
  membershipTier   String   @default("reader") // reader, patron, lifetime
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}
